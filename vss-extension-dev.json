{
  "manifestVersion": 1,
  "id": "sprint-report-generator-dev",
  "version": "2.18.1",
  "name": "Sprint Report Generator (Dev)",
  "description": "Local development version of Sprint Report Generator",
  "publisher": "agile-tools",
  "categories": ["Azure Boards"],
  "branding": {
    "color": "#0078d4",
    "theme": "dark"
  },
  "icons": {
    "default": "images/icon.png"
  },
  "tags": ["Azure DevOps", "Sprints", "Reports", "Metrics", "Boards"],
  "links": {
    "homepage": "https://github.com/archerax/ados-helper#readme",
    "support": "https://github.com/archerax/ados-helper/issues",
    "repository": "https://github.com/archerax/ados-helper"
  },
  "content": {
    "details": {
      "path": "src/extension/README.md"
    }
  },
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "scopes": ["vso.work", "vso.project"],
  "files": [
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "src/extension/README.md",
      "addressable": true
    }
  ],
  "baseUri": "http://localhost:5173",
  "contributions": [
    {
      "id": "sprints-reports-tab",
      "type": "ms.vss-web.tab",
      "targets": ["ms.vss-work-web.iteration-backlog-tabs"],
      "properties": {
        "name": "Reports",
        "uri": "index.html"
      }
    }
  ]
}
