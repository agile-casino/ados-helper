{
  "name": "ados-helper",
  "version": "2.11.0",
  "description": "ados-helper",
  "main": "src/index.tsx",
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:watch": "vite build --watch --mode development",
    "check": "pnpm build && pnpm test && pnpm lint",
    "lint": "npx prettier **/*.{md,yml} && biome check && knip",
    "lint:fix": "npx prettier --write **/*.{md,yml} && biome check --write && knip --fix",
    "tcm": "tcm src",
    "test": "vitest",
    "test:watch": "vitest",
    "knip": "knip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archerax/ados-helper.git"
  },
  "author": "archerax",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/archerax/ados-helper/issues"
  },
  "homepage": "https://github.com/archerax/ados-helper#readme",
  "packageManager": "pnpm@8.15.4",
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.6.0",
    "postcss-preset-mantine": "^1.18.0",
    "prettier": "^3.8.3",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@mantine/core": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "happy-dom": "^20.9.0",
    "lodash": "^4.18.1",
    "postcss": "^8.5.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript-plugin-css-modules": "^5.2.0",
    "xlsx-js-style": "^1.2.0"
  }
