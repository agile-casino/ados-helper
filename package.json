{
  "name": "sprint-report-generator",
  "version": "2.19.0",
  "description": "Sprint Report Generator",
  "main": "src/userscript/index.tsx",
  "scripts": {
    "build": "rm -rf node_modules/.vite && vite build",
    "build:dev": "rm -rf node_modules/.vite && vite build --mode development",
    "build:watch": "vite build --watch --mode development",
    "build:extension": "vite build --config vite.extension.config.mts",
    "dev:extension": "vite --config vite.extension.config.mts",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "dev": "vite",
    "lint": "prettier --check \"**/*.{md,yml}\" && biome check && knip",
    "lint:fix": "prettier --write \"**/*.{md,yml}\" && biome check --write && knip --fix",
    "tcm": "tcm src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "version": "node scripts/update-versions.js",
    "postinstall": "lefthook install"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agile-casino/ados-helper.git"
  },
  "author": "archerax",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/agile-casino/ados-helper/issues"
  },
  "homepage": "https://github.com/agile-casino/ados-helper#readme",
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065",
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.27.0",
    "lefthook": "2.1.10",
    "postcss-preset-mantine": "^1.18.0",
    "prettier": "^3.9.5",
    "tfx-cli": "^0.23.4",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-css-injected-by-js": "^5.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "azure-devops-extension-sdk": "^5.0.0",
    "happy-dom": "^20.11.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lodash": "^4.18.1",
    "postcss": "^8.5.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript-plugin-css-modules": "^5.2.0",
    "xlsx-js-style": "^1.2.0"
  }
}
