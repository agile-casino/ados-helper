{
  "name": "ados-helper",
  "version": "2.16.3",
  "description": "ados-helper",
  "main": "src/userscript/index.tsx",
  "scripts": {
    "build": "rm -rf node_modules/.vite && vite build",
    "build:dev": "rm -rf node_modules/.vite && vite build --mode development",
    "build:watch": "vite build --watch --mode development",
    "build:extension": "vite build --config vite.extension.config.mts",
    "dev:extension": "vite --config vite.extension.config.mts",
    "check": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "dev": "vite",
    "lint": "prettier --check \"**/*.{md,yml}\" && biome check && knip",
    "lint:fix": "prettier --write \"**/*.{md,yml}\" && biome check --write && knip --fix",
    "tcm": "tcm src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "version": "node scripts/update-versions.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archerax/ados-helper.git"
  },
  "author": "archerax",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/archerax/ados-helper/issues"
  },
  "homepage": "https://github.com/archerax/ados-helper#readme",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "knip": "^6.23.0",
    "postcss-preset-mantine": "^1.18.0",
    "prettier": "^3.9.3",
    "tfx-cli": "^0.23.3",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "azure-devops-extension-sdk": "^5.0.0",
    "happy-dom": "^20.10.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lodash": "^4.18.1",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript-plugin-css-modules": "^5.2.0",
    "xlsx-js-style": "^1.2.0"
  }
}
