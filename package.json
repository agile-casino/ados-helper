{
  "name": "ados-helper",
  "version": "2.15.2",
  "description": "ados-helper",
  "main": "src/userscript/index.tsx",
  "scripts": {
    "build": "rm -rf node_modules/.vite && vite build",
    "build:dev": "rm -rf node_modules/.vite && vite build --mode development",
    "build:watch": "vite build --watch --mode development",
    "check": "pnpm build && pnpm test && pnpm lint",
    "dev": "vite",
    "lint": "npx prettier **/*.{md,yml} && biome check && knip",
    "lint:fix": "npx prettier --write **/*.{md,yml} && biome check --write && knip --fix",
    "tcm": "tcm src",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "version": "node -e \"const fs = require('fs'); const tauri = JSON.parse(fs.readFileSync('./src-tauri/tauri.conf.json')); tauri.version = require('./package.json').version; fs.writeFileSync('./src-tauri/tauri.conf.json', JSON.stringify(tauri, null, 2) + '\\n');\" && git add src-tauri/tauri.conf.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/archerax/ados-helper.git"
  },
  "author": "archerax",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/archerax/ados-helper/issues"
  },
  "homepage": "https://github.com/archerax/ados-helper#readme",
  "packageManager": "pnpm@11.6.0",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/react": "^16.3.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "knip": "^6.17.1",
    "postcss-preset-mantine": "^1.18.0",
    "prettier": "^3.8.4",
    "typed-css-modules": "^0.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-bundle-analyzer": "^1.3.8",
    "vite-plugin-banner": "^0.8.1",
    "vite-plugin-checker": "^0.14.4",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "happy-dom": "^20.10.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lodash": "^4.18.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript-plugin-css-modules": "^5.2.0",
    "xlsx-js-style": "^1.2.0"
  }
}
