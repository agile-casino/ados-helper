{
  "manifestVersion": 1,
  "id": "ados-helper",
  "version": "2.16.0",
  "name": "ADOS Helper",
  "description": "Reports and metrics helper for Azure DevOps",
  "publisher": "ados-helper-publisher",
  "categories": ["Azure Boards"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "scopes": ["vso.work", "vso.project"],
  "files": [
    {
      "path": "dist-extension",
      "addressable": true
    }
  ],
  "contributions": [
    {
      "id": "sprints-reports-tab",
      "type": "ms.vss-web.tab",
      "targets": ["ms.vss-work-web.iteration-backlog-tabs"],
      "properties": {
        "name": "Reports",
        "uri": "dist-extension/index.html"
      }
    }
  ]
}
